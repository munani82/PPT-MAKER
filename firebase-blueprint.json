{
  "entities": {
    "DocumentMetadata": {
      "title": "Document Metadata",
      "description": "User's presentation metadata (orientation, timestamps).",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "orientation": { "type": "string", "enum": ["landscape", "portrait"] },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "orientation", "updatedAt"]
    },
    "SlideData": {
      "title": "Slide Data",
      "description": "Individual slide content with layers.",
      "type": "object",
      "properties": {
        "index": { "type": "integer", "description": "Position of the slide in the presentation." },
        "layers": { "type": "array" }
      },
      "required": ["index", "layers"]
    }
  },
  "firestore": {
    "/userStates/{userId}": {
      "schema": "DocumentMetadata",
      "description": "Metadata for the presentation."
    },
    "/userStates/{userId}/slides/{slideId}": {
      "schema": "SlideData",
      "description": "Individual slide documents."
    }
  }
}
