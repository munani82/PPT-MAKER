rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidDocumentState(data) {
      return data.keys().hasAll(['userId', 'slides', 'orientation', 'updatedAt']) &&
             data.userId is string &&
             data.slides is list &&
             data.orientation in ['landscape', 'portrait'] &&
             data.updatedAt is timestamp;
    }

    match /userStates/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidDocumentState(request.resource.data);
      allow update: if isOwner(userId) && isValidDocumentState(request.resource.data) &&
                    request.resource.data.userId == resource.data.userId;
      allow delete: if isOwner(userId);
    }
  }
}
