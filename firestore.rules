rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny for all other paths
    match /{document=**} {
      allow read, write: if false;
    }

    // Main user state and subcollections
    match /userStates/{userId} {
      // Root metadata document
      allow get, list, write: if request.auth != null && request.auth.uid == userId;

      // Slides subcollection - explicitly allow recursive matches for easier management
      match /slides/{document=**} {
        allow get, list, write: if request.auth != null && request.auth.uid == userId;
      }
    }
  }
}
